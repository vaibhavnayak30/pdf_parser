# Dense embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=64

# Sparse embedding 
SPARSE_EMBEDDING_MODEL=prithivida/Splade_PP_en_v1
SPARSE_EMBEDDING_BATCH_SIZE=64

# Provider API keys
OPENAI_API_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=paper_chunks

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=research-papers
MINIO_SECURE=false

# Chunking
CHUNK_MAX_TOKENS=768
CHUNK_TOKENIZER_MODEL=gpt-4o
SKIP_REFERENCE_SECTIONS=true

# Re-ranking
RERANK_ENABLED=true
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=20

# PDF ingestion
MIN_PDF_BYTES=1024
MAX_PDF_DOWNLOAD_BYTES=104857600

# Additional artifacts extraction
EXTRACT_IMAGES=false
EXTRACT_TABLE_IMAGES=false

_METADATA_MODEL=gpt-4o-mini